/* pages/history/history.wxss */

.page { padding: 0 0 40rpx; min-height: 100vh; }

/* ── 顶部工具栏 ─────────────────────────────────── */
.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: linear-gradient(135deg, #8B1A1A, #6B0F0F);
}
.toolbar-info { font-size: 26rpx; color: rgba(240,208,96,0.85); }
.clear-btn {
  font-size: 24rpx;
  font-weight: 700;
  color: #F0D060;
  border: 1rpx solid rgba(240,208,96,0.5);
  border-radius: 10rpx;
  padding: 8rpx 20rpx;
}

/* ── 筛选 tab 条 ─────────────────────────────────── */
.filter-bar {
  display: flex;
  flex-direction: row;
  white-space: nowrap;
  padding: 16rpx 20rpx 12rpx;
  background: #F5F0E8;
  border-bottom: 2rpx solid rgba(212,175,55,0.15);
}
.filter-tab {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #8B5A2B;
  background: rgba(212,175,55,0.10);
  border: 2rpx solid rgba(212,175,55,0.22);
  border-radius: 32rpx;
  flex-shrink: 0;
  white-space: nowrap;
}
.filter-active {
  color: #F0D060;
  background: linear-gradient(135deg, #8B1A1A, #C0392B);
  border-color: transparent;
  box-shadow: 0 4rpx 12rpx rgba(139,26,26,0.22);
}

/* ── 空状态 ─────────────────────────────────────── */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}
.empty-icon  { font-size: 120rpx; margin-bottom: 24rpx; opacity: 0.5; }
.empty-text  { font-size: 32rpx; font-weight: 700; color: #888; }
.empty-sub   { font-size: 24rpx; color: #AAA; margin-top: 12rpx; }

/* ── 历史列表 ────────────────────────────────────── */
.list { padding: 20rpx 24rpx 0; }

.hist-item {
  margin-bottom: 20rpx;
  border: 2rpx solid rgba(212,175,55,0.18);
  overflow: visible;
}

/* ── 摘要行 ─────────────────────────────────────── */
.hi-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  gap: 16rpx;
}
.hi-left { display: flex; align-items: flex-start; gap: 16rpx; flex: 1; min-width: 0; }
.hi-round-badge {
  background: linear-gradient(135deg, #8B1A1A, #C0392B);
  color: #F0D060;
  font-size: 22rpx;
  font-weight: 800;
  padding: 8rpx 14rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
  letter-spacing: 1rpx;
}
.hi-info { flex: 1; min-width: 0; }
.hi-op {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 胡牌者/点炮者/庄家标签行 */
.hi-meta-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-top: 6rpx;
  gap: 2rpx;
}
.hi-winner {
  font-size: 22rpx;
  color: #C8960C;
  font-weight: 600;
}
.hi-sep {
  font-size: 22rpx;
  color: #CCC;
}
.hi-shooter {
  font-size: 22rpx;
  color: #888;
}
.hi-zhuang-tag {
  margin-left: 8rpx;
  font-size: 18rpx;
  font-weight: 800;
  color: #F0D060;
  background: linear-gradient(135deg, #8B1A1A, #C0392B);
  border-radius: 6rpx;
  padding: 2rpx 8rpx;
  vertical-align: middle;
}
.hi-lian {
  display: block;
  font-size: 20rpx;
  color: #C0392B;
  margin-top: 4rpx;
  font-weight: 600;
}

.hi-right { text-align: right; flex-shrink: 0; }
.hi-time   { display: block; font-size: 20rpx; color: #BBB; }
.hi-expand { display: block; font-size: 20rpx; color: #C9A64D; margin-top: 8rpx; }

/* ── 展开详情 ───────────────────────────────────── */
.hi-detail { padding: 4rpx 24rpx 16rpx; }

.detail-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  gap: 10rpx;
  border-bottom: 1rpx dashed rgba(212,175,55,0.15);
}
.detail-row:last-of-type { border-bottom: none; }
.dr-name {
  font-size: 26rpx; font-weight: 700; color: #4A2800;
  width: 110rpx; flex-shrink: 0;
}
.dr-delta {
  font-size: 30rpx; font-weight: 800;
  width: 90rpx; text-align: right; flex-shrink: 0;
}
.dr-arrow { font-size: 20rpx; color: #CCC; flex-shrink: 0; }
.dr-total { font-size: 24rpx; color: #666; flex: 1; }

/* ── 倍率明细小字 ───────────────────────────────── */
.breakdown-info {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  padding: 10rpx 0 4rpx;
  font-size: 20rpx;
  color: #AAA;
  gap: 4rpx;
}
.breakdown-label {
  font-size: 20rpx;
  color: #C9A64D;
  font-weight: 700;
  margin-right: 4rpx;
}

/* ── 删除按钮 ────────────────────────────────────── */
.delete-row { text-align: center; padding-top: 16rpx; }
.del-btn {
  display: inline-block;
  font-size: 24rpx;
  color: #C0392B;
  border: 1rpx solid rgba(192,57,43,0.3);
  border-radius: 10rpx;
  padding: 10rpx 28rpx;
}
