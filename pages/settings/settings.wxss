/* pages/settings/settings.wxss */

.page { padding: 24rpx 0 80rpx; }

/* ── 未保存提示条 ────────────────────────────────── */
.tip-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #C0392B, #8B1A1A);
  padding: 18rpx 28rpx;
  margin-bottom: 8rpx;
}
.tip-text { font-size: 26rpx; color: rgba(255,255,255,0.9); }
.tip-save {
  font-size: 24rpx; font-weight: 700;
  color: #F0D060;
  border: 1rpx solid rgba(240,208,96,0.6);
  border-radius: 10rpx;
  padding: 6rpx 20rpx;
}

/* ── 分区标题 ────────────────────────────────────── */
.section-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #8B1A1A;
  padding: 28rpx 30rpx 12rpx;
  letter-spacing: 1rpx;
}

/* ── 内容区域 ────────────────────────────────────── */
.section {
  margin: 0 24rpx;
  padding: 0 28rpx;
  border: 2rpx solid rgba(212,175,55,0.18);
}

/* ── 单行设置 ────────────────────────────────────── */
.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  gap: 16rpx;
}
.sr-left { flex: 1; min-width: 0; }
.sr-label {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
}
.sr-desc {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}
.sr-input {
  width: 120rpx;
  height: 64rpx;
  border: 2rpx solid rgba(212,175,55,0.5);
  border-radius: 12rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #8B1A1A;
  background: #FBF8F2;
  flex-shrink: 0;
}
.sr-input-wrap {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-shrink: 0;
}
.sr-unit {
  font-size: 24rpx;
  color: #C9A64D;
  font-weight: 700;
}

/* ── 保存按钮 ────────────────────────────────────── */
.save-btn {
  margin: 28rpx 24rpx;
  padding: 28rpx 0;
  text-align: center;
  font-size: 32rpx;
  font-weight: 800;
  color: #F0D060;
  background: linear-gradient(135deg, #8B1A1A, #C0392B);
  border-radius: 20rpx;
  letter-spacing: 4rpx;
  box-shadow: 0 6rpx 20rpx rgba(139,26,26,0.30);
}

/* ── 危险操作行 ─────────────────────────────────── */
.danger-row {
  display: flex;
  align-items: center;
  padding: 22rpx 0;
  gap: 16rpx;
}
.danger-icon { font-size: 36rpx; flex-shrink: 0; }
.dr-text { flex: 1; }
.dr-label { display: block; font-size: 28rpx; font-weight: 700; color: #333; }
.dr-desc  { display: block; font-size: 22rpx; color: #999; margin-top: 4rpx; }
.dr-arrow { font-size: 36rpx; color: #CCC; font-weight: 300; }

/* ── Toggle 开关 ─────────────────────────────────── */
.toggle-switch {
  width: 90rpx; height: 48rpx;
  background: #DDD;
  border-radius: 24rpx;
  padding: 6rpx;
  display: flex;
  align-items: center;
  flex-shrink: 0;
  transition: background 0.22s;
}
.toggle-on { background: #C0392B; }
.toggle-knob {
  width: 36rpx; height: 36rpx;
  background: #FFF;
  border-radius: 50%;
  transition: transform 0.22s;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.22);
}
.toggle-on .toggle-knob { transform: translateX(42rpx); }

/* ── 庄家规则说明 ─────────────────────────────────── */
.zhuang-rules {
  padding: 12rpx 0 8rpx;
}
.zr-item {
  display: block;
  font-size: 22rpx;
  color: #888;
  line-height: 1.9;
  padding: 2rpx 0;
}
.zr-off { color: #AAAAAA; font-style: italic; }

/* ── 番型列表 ────────────────────────────────────── */
.fan-header {
  display: flex;
  align-items: center;
  padding: 16rpx 0 4rpx;
  gap: 12rpx;
}
.fan-hname   { flex: 1; font-size: 22rpx; color: #C9A64D; font-weight: 700; }
.fan-hrate   { width: 130rpx; text-align: center; font-size: 22rpx; color: #C9A64D; font-weight: 700; }
.fan-htoggle { width: 90rpx;  text-align: center; font-size: 22rpx; color: #C9A64D; font-weight: 700; }

.fan-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  gap: 12rpx;
}
.fan-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  min-width: 0;
}
.fan-rate-input {
  width: 80rpx;
}

/* ── 导入弹窗 ────────────────────────────────────── */
.import-modal {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}
.import-overlay {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.52);
}
.import-card {
  position: relative;
  z-index: 201;
  background: #FFFEF8;
  border-radius: 24rpx;
  width: 620rpx;
  padding: 40rpx 32rpx 32rpx;
  box-shadow: 0 12rpx 40rpx rgba(139,26,26,0.22);
  border: 2rpx solid rgba(212,175,55,0.25);
}
.import-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #8B1A1A;
  text-align: center;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}
.import-hint {
  display: block;
  font-size: 22rpx;
  color: #999;
  text-align: center;
  margin-bottom: 20rpx;
}
.import-input {
  width: 100%;
  height: 200rpx;
  background: #F7F2E8;
  border: 2rpx solid rgba(212,175,55,0.4);
  border-radius: 14rpx;
  padding: 18rpx;
  font-size: 22rpx;
  color: #444;
  box-sizing: border-box;
  line-height: 1.6;
}
.import-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 28rpx;
}
.import-btn-cancel {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #888;
  background: #F0EBE0;
  border-radius: 14rpx;
}
.import-btn-confirm {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 800;
  color: #F0D060;
  background: linear-gradient(135deg, #8B1A1A, #C0392B);
  border-radius: 14rpx;
  box-shadow: 0 4rpx 14rpx rgba(139,26,26,0.28);
}

/* ── 示例说明（兼容旧版） ────────────────────────── */
.example-card { padding: 20rpx 28rpx !important; }
.example-text {
  display: block;
  font-size: 22rpx;
  color: #666;
  line-height: 1.8;
  padding: 4rpx 0;
}
