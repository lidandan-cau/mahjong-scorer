/* pages/index/index.wxss  v2.0 */

/* ─── 页面容器 ──────────────────────────────────── */
.page { padding: 0 0 200rpx; min-height: 100vh; }

/* ─── 顶部标题栏 ─────────────────────────────────── */
.header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 32rpx 30rpx 24rpx;
  background: linear-gradient(135deg, #8B1A1A 0%, #6B0F0F 100%);
  box-shadow: 0 4rpx 16rpx rgba(139,26,26,0.35);
}
.header-deco { font-size: 44rpx; opacity: 0.8; }
.header-center { text-align: center; flex: 1; }
.header-title {
  display: block; font-size: 42rpx; font-weight: 800;
  color: #F0D060; letter-spacing: 4rpx;
  text-shadow: 0 2rpx 6rpx rgba(0,0,0,0.4);
}
.header-meta { margin-top: 8rpx; display: flex; align-items: center; justify-content: center; flex-wrap: wrap; }
.meta-item { font-size: 21rpx; color: rgba(240,208,96,0.85); }
.meta-sep  { font-size: 21rpx; color: rgba(240,208,96,0.4); margin: 0 8rpx; }
.lian-tag  { color: #FFE082; font-weight: 800; }

/* ─── 四玩家网格 ─────────────────────────────────── */
.players-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; padding: 20rpx 20rpx 0;
}
.player-card {
  padding: 18rpx 14rpx 14rpx; position: relative;
  border: 2rpx solid rgba(212,175,55,0.2); transition: border-color 0.2s;
  border-radius: 20rpx;
  background: #FFFEF8;
  box-shadow: 0 4rpx 16rpx rgba(139,26,26,0.08);
}
.card-zhuang { border: 3rpx solid #D4AF37; box-shadow: 0 4rpx 20rpx rgba(212,175,55,0.28); }
.card-hidden { padding: 14rpx; justify-content: center; }

/* 隐藏态 */
.hidden-card { display: flex; flex-direction: column; align-items: center; padding: 8rpx 0; }
.hc-name  { font-size: 24rpx; font-weight: 700; color: #888; }
.hc-score { font-size: 30rpx; font-weight: 800; margin: 8rpx 0; }
.hc-show  {
  font-size: 20rpx; color: #C9A64D; border: 1rpx solid rgba(201,166,77,0.4);
  border-radius: 8rpx; padding: 4rpx 12rpx; margin-top: 4rpx;
}

/* 名称行：[名字✏] flex-1  [庄]  [重置] 同行排列 */
.player-name-row {
  display: flex; align-items: center;
  padding-bottom: 10rpx; border-bottom: 2rpx dashed rgba(212,175,55,0.22);
  gap: 8rpx;
}
.player-name-tap { display: flex; align-items: center; gap: 4rpx; flex: 1; min-width: 0; }
.player-name { font-size: 26rpx; font-weight: 700; color: #4A2800; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.edit-hint   { font-size: 20rpx; color: #C9A64D; opacity: 0.7; flex-shrink: 0; }

/* 庄标识：位于名字与重置之间 */
.zhuang-badge {
  font-size: 22rpx; font-weight: 900;
  width: 52rpx; height: 52rpx;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; border: 2rpx solid;
}
.zhuang-on {
  background: linear-gradient(135deg, #C9A64D, #D4AF37);
  color: #FFF; border-color: #D4AF37;
  box-shadow: 0 3rpx 10rpx rgba(212,175,55,0.55);
}
.zhuang-off {
  background: rgba(212,175,55,0.07);
  color: #C9A64D; border-color: rgba(201,166,77,0.32);
}
/* 重置按钮：在庄标右侧，右上角位置 */
.reset-player {
  font-size: 19rpx; color: #C9A64D;
  border: 1rpx solid rgba(201,166,77,0.4);
  border-radius: 8rpx; padding: 5rpx 12rpx;
  flex-shrink: 0;
}
.hide-btn   { display: none; }
.card-footer{ display: none; }

/* 分数区 */
.score-area { padding: 10rpx 2rpx 4rpx; }
.score-row  { display: flex; align-items: center; justify-content: space-between; margin: 3rpx 0; }
.score-label { font-size: 20rpx; color: #AAA; }
.score-val   { font-size: 28rpx; font-weight: 700; }
.score-val.big { font-size: 38rpx; }
.score-divider { height: 1rpx; background: linear-gradient(90deg, transparent, #E8D5B0, transparent); margin: 4rpx 0; }

/* ─── 操作分组 ──────────────────────────────────── */
.op-group {
  margin: 16rpx 20rpx 0;
  background: #FFFEF8;
  border-radius: 20rpx;
  padding: 16rpx 18rpx 14rpx;
  box-shadow: 0 4rpx 16rpx rgba(139,26,26,0.08);
  border: 2rpx solid rgba(212,175,55,0.15);
}
.op-group-last { margin-bottom: 0; }
.op-group-title { display: block; font-size: 22rpx; font-weight: 700; color: #C9A64D; margin-bottom: 12rpx; letter-spacing: 1rpx; }
.op-row-main { display: flex; gap: 12rpx; margin-bottom: 12rpx; }
.op-row-main:last-child { margin-bottom: 0; }
.op-row-single .op-btn { flex: 0 0 calc(50% - 6rpx); }

.op-btn {
  flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 18rpx 0; border-radius: 16rpx; gap: 4rpx;
  box-shadow: 0 3rpx 10rpx rgba(0,0,0,0.12);
}
.op-icon { font-size: 32rpx; }
.op-text { font-size: 24rpx; font-weight: 700; color: #FFF; letter-spacing: 1rpx; }

.btn-red       { background: linear-gradient(135deg, #8B1A1A, #C0392B); }
.btn-gold      { background: linear-gradient(135deg, #C9A64D, #D4AF37); }
.btn-green     { background: linear-gradient(135deg, #1A6B2A, #27AE60); }
.btn-darkblue  { background: linear-gradient(135deg, #1A3A6B, #2756AE); }
.btn-purple    { background: linear-gradient(135deg, #4A1A6B, #8B3AAE); }
.btn-darkgreen { background: linear-gradient(135deg, #0F4020, #1A6B3A); }
.btn-teal      { background: linear-gradient(135deg, #0F3D3D, #1A7A7A); }
.btn-slate     { background: linear-gradient(135deg, #2A3040, #455A80); }

/* 辅助操作行 */
.op-row-sub { display: flex; gap: 12rpx; margin-bottom: 10rpx; }
.op-row-sub:last-child { margin-bottom: 0; }
.sub-btn {
  flex: 1; text-align: center; padding: 18rpx 0; border-radius: 14rpx;
  font-size: 24rpx; font-weight: 600; border: 2rpx solid;
}
.btn-liuju { color: #1A7A7A; border-color: rgba(26,122,122,0.4); background: rgba(26,122,122,0.05); }
.btn-manual{ color: #6B3AAE; border-color: rgba(107,58,174,0.4); background: rgba(107,58,174,0.05); }
.btn-undo  { color: #8B1A1A; border-color: rgba(139,26,26,0.4); background: rgba(139,26,26,0.05); }
.btn-clear { color: #5A5A5A; border-color: rgba(90,90,90,0.3); background: rgba(90,90,90,0.04); }
.btn-disabled { opacity: 0.32; }

/* ─── 底部导航 ──────────────────────────────────── */
.bottom-nav {
  position: fixed; bottom: 0; left: 0; right: 0;
  display: flex; background: #FFFEF8;
  border-top: 2rpx solid rgba(212,175,55,0.22);
  box-shadow: 0 -4rpx 16rpx rgba(139,26,26,0.07);
  padding-bottom: env(safe-area-inset-bottom); z-index: 50;
}
.nav-btn { flex: 1; display: flex; flex-direction: column; align-items: center; padding: 16rpx 0 14rpx; gap: 4rpx; }
.nav-icon  { font-size: 36rpx; }
.nav-label { font-size: 20rpx; color: #8B1A1A; font-weight: 600; }

/* ─── 操作面板 ──────────────────────────────────── */
.op-panel {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: #FFFEF8; border-radius: 32rpx 32rpx 0 0;
  box-shadow: 0 -8rpx 40rpx rgba(139,26,26,0.18);
  z-index: 200; padding: 0 0 env(safe-area-inset-bottom);
  transform: translateY(100%); pointer-events: none;
  transition: transform 0.32s cubic-bezier(0.32,0.72,0,1);
  max-height: 85vh; display: flex; flex-direction: column;
}
.op-panel-show { transform: translateY(0); pointer-events: auto; }

.panel-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 24rpx 28rpx 0; flex-shrink: 0;
}
.panel-close {
  width: 56rpx; height: 56rpx; display: flex; align-items: center; justify-content: center;
  font-size: 30rpx; color: #888; background: rgba(0,0,0,0.06); border-radius: 50%;
}
.panel-title { font-size: 32rpx; font-weight: 800; color: #8B1A1A; letter-spacing: 2rpx; }

.panel-scroll { flex: 1; overflow: hidden; }
.panel-hint { display: block; text-align: center; font-size: 24rpx; color: #C9A64D; font-weight: 600; padding: 14rpx 28rpx 4rpx; letter-spacing: 1rpx; }

/* 玩家选择网格 */
.panel-players { display: grid; grid-template-columns: 1fr 1fr; gap: 14rpx; padding: 12rpx 28rpx; }
.psel-btn {
  position: relative; display: flex; flex-direction: column; align-items: center;
  padding: 14rpx 10rpx 10rpx; background: #F8F4EE; border-radius: 14rpx;
  border: 2rpx solid transparent; transition: all 0.15s;
}
.psel-zhuang-tag {
  position: absolute; top: -6rpx; left: -6rpx;
  font-size: 16rpx; font-weight: 800; width: 28rpx; height: 28rpx;
  border-radius: 50%; display: flex; align-items: center; justify-content: center;
  background: linear-gradient(135deg, #C9A64D, #D4AF37); color: #FFF;
}
.psel-name    { font-size: 26rpx; font-weight: 700; color: #4A2800; }
.psel-score   { font-size: 20rpx; margin-top: 3rpx; font-weight: 600; }
.psel-preview { font-size: 24rpx; font-weight: 800; margin-top: 4rpx; }
.psel-winner  { background: linear-gradient(135deg, rgba(139,26,26,0.08), rgba(192,57,43,0.12)); border-color: #C0392B; }
.psel-shooter { background: linear-gradient(135deg, rgba(139,100,26,0.08), rgba(201,166,77,0.15)); border-color: #C9A64D; }
.psel-disabled{ opacity: 0.28; pointer-events: none; }
.psel-badge {
  position: absolute; top: -8rpx; right: -8rpx;
  font-size: 18rpx; font-weight: 800; width: 32rpx; height: 32rpx;
  border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #FFF;
}
.psel-badge-win  { background: #C0392B; }
.psel-badge-shot { background: #C9A64D; }

/* 杠类型选择 */
.gang-type-row { padding: 4rpx 28rpx 10rpx; }
.gtr-label { font-size: 22rpx; color: #888; display: block; margin-bottom: 10rpx; }
.gang-type-btns { display: flex; gap: 16rpx; }
.gtype-btn {
  flex: 1; text-align: center; padding: 14rpx 0; border-radius: 12rpx;
  font-size: 24rpx; font-weight: 700; color: #666;
  background: #F0EBE0; border: 2rpx solid transparent;
}
.gtype-on { color: #8B1A1A; background: rgba(139,26,26,0.08); border-color: #C0392B; }

/* 番型入口 */
.fan-entry {
  margin: 4rpx 28rpx; padding: 14rpx 20rpx;
  background: #F8F4EE; border-radius: 12rpx; border: 1rpx solid rgba(212,175,55,0.3);
  display: flex; align-items: center; justify-content: space-between;
}
.fe-label  { font-size: 24rpx; font-weight: 600; color: #4A2800; }
.fe-val    { font-size: 22rpx; color: #AAA; }
.fe-active { color: #C9A64D; font-weight: 700; }

/* 大胡加倍 */
.double-row { display: flex; align-items: center; gap: 14rpx; padding: 8rpx 28rpx 6rpx; }
.double-toggle {
  width: 72rpx; height: 40rpx; background: #DDD; border-radius: 20rpx; padding: 4rpx;
  transition: background 0.2s; flex-shrink: 0;
}
.double-on { background: #C0392B; }
.toggle-dot {
  width: 32rpx; height: 32rpx; background: #FFF; border-radius: 50%;
  transition: transform 0.2s; box-shadow: 0 2rpx 5rpx rgba(0,0,0,0.2);
}
.double-on .toggle-dot { transform: translateX(32rpx); }
.double-label { font-size: 24rpx; font-weight: 600; color: #4A2800; }
.double-hint  { font-size: 21rpx; color: #C0392B; font-weight: 600; }

/* 庄家提示 */
.zhuang-tip {
  margin: 4rpx 28rpx; padding: 10rpx 18rpx;
  background: rgba(212,175,55,0.1); border: 1rpx solid rgba(212,175,55,0.35);
  border-radius: 10rpx; text-align: center;
}
.zhuang-tip-text { font-size: 22rpx; font-weight: 700; color: #C9A64D; }

/* 面板底部按钮 */
.panel-footer { display: flex; gap: 16rpx; padding: 12rpx 28rpx 20rpx; flex-shrink: 0; }
.pfooter-cancel {
  flex: 1; text-align: center; padding: 22rpx 0; border-radius: 14rpx;
  font-size: 26rpx; font-weight: 600; color: #888; background: rgba(0,0,0,0.05);
}
.pfooter-confirm {
  flex: 2; text-align: center; padding: 22rpx 0; border-radius: 14rpx;
  font-size: 28rpx; font-weight: 800; color: #F0D060;
  background: linear-gradient(135deg, #8B1A1A, #C0392B);
  box-shadow: 0 4rpx 14rpx rgba(139,26,26,0.32); letter-spacing: 2rpx;
}

/* 番型列表 overlay */
.fan-list-overlay {
  display: flex; flex-direction: column; flex: 1;
  background: #FFFEF8; padding: 0 0 16rpx;
}
.fan-list-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16rpx 28rpx 12rpx;
  border-bottom: 2rpx solid rgba(212,175,55,0.15);
}
.fh-title { font-size: 28rpx; font-weight: 700; color: #4A2800; }
.fh-done  { font-size: 26rpx; font-weight: 700; color: #C9A64D; padding: 6rpx 16rpx; }
.fan-list { padding: 12rpx 28rpx; overflow-y: auto; max-height: 380rpx; }
.fan-item {
  display: flex; align-items: center; padding: 18rpx 20rpx;
  background: #F8F4EE; border-radius: 14rpx; margin-bottom: 12rpx;
  border: 2rpx solid transparent;
}
.fan-item-on { background: rgba(139,26,26,0.06); border-color: #C0392B; }
.fi-name  { flex: 1; font-size: 28rpx; font-weight: 700; color: #4A2800; }
.fi-rate  { font-size: 24rpx; font-weight: 600; color: #C9A64D; margin-right: 16rpx; }
.fi-check { font-size: 28rpx; font-weight: 800; color: #C0392B; width: 36rpx; text-align: center; }

/* ─── 结算弹窗 ──────────────────────────────────── */
.settle-popup {
  position: fixed; top: 50%; left: 36rpx; right: 36rpx; transform: translateY(-50%);
  z-index: 200; padding: 0 0 4rpx; animation: popIn 0.28s ease;
}
@keyframes popIn { from { transform: translateY(-50%) scale(0.88); opacity: 0; } to { transform: translateY(-50%) scale(1); opacity: 1; } }
.settle-header {
  background: linear-gradient(135deg, #8B1A1A, #6B0F0F);
  border-radius: 20rpx 20rpx 0 0; padding: 24rpx 28rpx 18rpx; text-align: center;
}
.settle-round  { display: block; font-size: 30rpx; font-weight: 800; color: #F0D060; letter-spacing: 3rpx; }
.settle-op     { display: block; font-size: 22rpx; color: rgba(240,208,96,0.75); margin-top: 6rpx; }
.settle-winner { display: block; font-size: 24rpx; color: #FFFCE0; margin-top: 8rpx; font-weight: 600; }
.settle-rows   { padding: 8rpx 28rpx; }
.settle-row    { display: flex; align-items: center; justify-content: space-between; padding: 14rpx 0; border-bottom: 1rpx dashed rgba(212,175,55,0.18); }
.settle-row:last-child { border-bottom: none; }
.sr-name  { font-size: 26rpx; font-weight: 700; color: #4A2800; width: 110rpx; }
.sr-right { display: flex; align-items: center; gap: 10rpx; }
.sr-delta { font-size: 30rpx; font-weight: 800; width: 90rpx; text-align: right; }
.sr-arrow { font-size: 20rpx; color: #CCC; }
.sr-total { font-size: 26rpx; font-weight: 700; width: 90rpx; text-align: right; }
.settle-breakdown { text-align: center; padding: 8rpx 28rpx 4rpx; }
.sb-item { font-size: 22rpx; color: #C9A64D; font-weight: 700; }
.sb-sep  { font-size: 22rpx; color: #CCC; }
.settle-choice { display: flex; gap: 20rpx; padding: 16rpx 28rpx 20rpx; }
.sc-lian {
  flex: 1; text-align: center; padding: 22rpx 0; border-radius: 14rpx;
  font-size: 28rpx; font-weight: 800; color: #FFF;
  background: linear-gradient(135deg, #C0392B, #8B1A1A);
  box-shadow: 0 4rpx 12rpx rgba(139,26,26,0.3);
}
.sc-huan {
  flex: 1; text-align: center; padding: 22rpx 0; border-radius: 14rpx;
  font-size: 28rpx; font-weight: 800; color: #4A2800;
  background: linear-gradient(135deg, #D4AF37, #C9A64D);
  box-shadow: 0 4rpx 12rpx rgba(212,175,55,0.3);
}
.settle-footer {
  text-align: center; padding: 18rpx 28rpx 22rpx;
  font-size: 28rpx; font-weight: 800; color: #8B1A1A; letter-spacing: 2rpx;
  background: rgba(212,175,55,0.08); border-radius: 0 0 20rpx 20rpx;
}

/* ─── 流局弹窗 ──────────────────────────────────── */
.liuju-popup {
  position: fixed; top: 50%; left: 80rpx; right: 80rpx; transform: translateY(-50%);
  z-index: 200; padding: 36rpx 32rpx 28rpx; text-align: center; animation: popIn 0.25s ease;
}
.lp-title { display: block; font-size: 36rpx; font-weight: 800; color: #1A7A7A; margin-bottom: 20rpx; }
.lp-rules { padding: 10rpx 0; }
.lp-rule  { display: block; font-size: 24rpx; color: #666; line-height: 2; text-align: left; }
.lp-btns  { display: flex; gap: 16rpx; margin-top: 24rpx; }
.lp-cancel { flex: 1; text-align: center; padding: 22rpx 0; border-radius: 14rpx; font-size: 26rpx; font-weight: 600; color: #888; background: #F0EBE0; }
.lp-confirm{
  flex: 1; text-align: center; padding: 22rpx 0; border-radius: 14rpx;
  font-size: 26rpx; font-weight: 800; color: #FFF;
  background: linear-gradient(135deg, #1A7A7A, #0F4040);
}

/* ─── 手动加减分弹窗 ─────────────────────────────── */
.manual-popup {
  /* 左右留 20rpx，比结算弹窗更宽，内容更宽敞 */
  position: fixed; top: 50%; left: 20rpx; right: 20rpx; transform: translateY(-50%);
  z-index: 200; padding: 36rpx 32rpx 32rpx; animation: popIn 0.25s ease;
}
.manual-title { display: block; font-size: 34rpx; font-weight: 800; color: #6B3AAE; text-align: center; margin-bottom: 10rpx; }
.manual-hint  { display: block; font-size: 24rpx; color: #888; text-align: center; margin-bottom: 6rpx; }
.manual-warn  { display: block; font-size: 22rpx; color: #AAA; text-align: center; margin-bottom: 20rpx; }
.manual-players { display: flex; gap: 14rpx; margin-bottom: 18rpx; flex-wrap: wrap; }
.mp-btn {
  flex: 1; min-width: 120rpx; text-align: center;
  /* 加高按钮，字更易点击 */
  padding: 20rpx 8rpx; border-radius: 14rpx;
  font-size: 28rpx; font-weight: 700; color: #666; background: #F0EBE0;
  border: 2rpx solid transparent;
}
.mp-btn-on { color: #6B3AAE; border-color: #8B3AAE; background: rgba(107,58,174,0.08); }
.manual-presets { display: flex; gap: 12rpx; margin-bottom: 18rpx; }
.mp-preset {
  flex: 1; text-align: center; padding: 18rpx 0; border-radius: 12rpx;
  font-size: 28rpx; font-weight: 700; color: #8B1A1A;
  background: rgba(139,26,26,0.07); border: 1rpx solid rgba(139,26,26,0.2);
}
.manual-input {
  width: 100%;
  /* 微信小程序 input 必须显式设置 height，否则文字被截断 */
  height: 88rpx;
  padding: 0 24rpx;
  border: 2rpx solid rgba(212,175,55,0.5);
  border-radius: 14rpx;
  font-size: 30rpx;
  color: #333;
  background: #FBF8F2;
  box-sizing: border-box;
  text-align: center;
  margin-bottom: 22rpx;
  display: block;
  line-height: 88rpx;   /* 垂直居中 */
}
.manual-btns { display: flex; gap: 16rpx; }
.mb-cancel  { flex: 1; text-align: center; padding: 24rpx 0; border-radius: 14rpx; font-size: 28rpx; font-weight: 600; color: #888; background: #F0EBE0; }
.mb-confirm { flex: 1; text-align: center; padding: 24rpx 0; border-radius: 14rpx; font-size: 28rpx; font-weight: 800; color: #FFF; background: linear-gradient(135deg, #6B3AAE, #8B3AAE); }

/* ─── 改名弹窗 ──────────────────────────────────── */
.rename-popup {
  position: fixed; top: 50%; left: 80rpx; right: 80rpx; transform: translateY(-50%);
  z-index: 200; padding: 36rpx 32rpx 28rpx; text-align: center; animation: popIn 0.25s ease;
}
.rename-title { display: block; font-size: 30rpx; font-weight: 800; color: #8B1A1A; margin-bottom: 24rpx; letter-spacing: 2rpx; }
.rename-input {
  width: 100%; padding: 16rpx 20rpx; border: 2rpx solid rgba(212,175,55,0.5);
  border-radius: 12rpx; font-size: 28rpx; color: #333; background: #FBF8F2;
  box-sizing: border-box; text-align: center;
}
.rename-btns { display: flex; gap: 16rpx; margin-top: 24rpx; }
.rbtn-cancel  { flex: 1; padding: 22rpx 0; border-radius: 12rpx; font-size: 26rpx; font-weight: 600; color: #888; background: rgba(0,0,0,0.05); text-align: center; }
.rbtn-confirm { flex: 1; padding: 22rpx 0; border-radius: 12rpx; font-size: 26rpx; font-weight: 800; color: #FFF; background: linear-gradient(135deg, #8B1A1A, #C0392B); text-align: center; }
